<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wenli Zhang | Digital Marketing & Content Analytics Portfolio</title>
  <style>
    :root {
      --bg: #f7f5f2;
      --card: #ffffff;
      --text: #1f2933;
      --muted: #6b7280;
      --line: #e5e7eb;
      --accent: #6f5b4f;
      --accent-soft: #efe8e3;
      --dark: #111827;
      --ink: #25221f;
      --green-soft: #edf2ea;
      --tech-soft: #eef0f4;
      --gold-soft: #f6eee0;
    }

    * {
      box-sizing: border-box;
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      background:
        radial-gradient(circle at top right, rgba(111, 91, 79, 0.10), transparent 28%),
        linear-gradient(180deg, #faf8f4 0%, var(--bg) 42%, #f4f1ec 100%);
      color: var(--text);
      line-height: 1.6;
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    .container {
      width: min(1120px, 92%);
      margin: 0 auto;
    }

    header {
      background: rgba(247, 245, 242, 0.93);
      border-bottom: 1px solid var(--line);
      position: sticky;
      top: 0;
      z-index: 10;
      backdrop-filter: blur(12px);
    }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 0;
    }

    nav .logo {
      font-weight: 750;
      letter-spacing: -0.02em;
      color: var(--dark);
    }

    nav .links {
      display: flex;
      gap: 18px;
      font-size: 14px;
    }

    .hero {
      padding: 86px 0 64px;
    }

    .badge {
      display: inline-block;
      padding: 7px 12px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent);
      font-size: 13px;
      font-weight: 650;
      margin-bottom: 18px;
    }

    .badge.dark {
      background: var(--dark);
      color: white;
    }

    h1 {
      font-size: clamp(40px, 6vw, 70px);
      line-height: 1.05;
      margin: 0 0 18px;
      letter-spacing: -0.055em;
      color: var(--dark);
      max-width: 980px;
    }

    h2 {
      font-size: 31px;
      line-height: 1.2;
      letter-spacing: -0.035em;
      margin: 0 0 16px;
      color: var(--dark);
    }

    h3 {
      font-size: 20px;
      margin: 0 0 10px;
      color: var(--dark);
    }

    h4 {
      margin: 0 0 8px;
      color: var(--dark);
    }

    p {
      margin: 0 0 14px;
    }

    .hero-text {
      max-width: 880px;
      font-size: 19px;
      color: var(--muted);
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 28px;
    }

    .button {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 650;
      border: 1px solid var(--accent);
      background: var(--accent);
      color: white;
    }

    .button.secondary {
      background: transparent;
      color: var(--accent);
    }

    section {
      padding: 56px 0;
      border-top: 1px solid var(--line);
    }

    .grid {
      display: grid;
      gap: 18px;
    }

    .grid.two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .grid.three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .grid.four {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .card {
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(17, 24, 39, 0.04);
    }

    .card.soft {
      background: #fbfaf8;
    }

    .card.tech {
      background: linear-gradient(145deg, #ffffff 0%, #f3f5f5 100%);
      border-color: #dfe3e4;
    }

    .card.gold {
      background: var(--gold-soft);
      border-color: #eadcc4;
    }

    .section-intro {
      max-width: 820px;
      color: var(--muted);
      margin-bottom: 24px;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }

    .tag {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent);
      font-size: 12px;
      font-weight: 650;
    }

    .tag.tech {
      background: var(--tech-soft);
      color: #374151;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      overflow: hidden;
      border-radius: 16px;
      background: var(--card);
    }

    th, td {
      padding: 14px;
      text-align: left;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }

    th {
      background: #f1eee9;
      color: var(--dark);
      font-size: 13px;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .quote {
      font-size: 22px;
      line-height: 1.4;
      color: var(--dark);
      border-left: 4px solid var(--accent);
      padding-left: 18px;
      margin: 24px 0;
    }

    .callout {
      border-radius: 24px;
      padding: 28px;
      background: linear-gradient(135deg, #1f2933 0%, #3d3630 100%);
      color: white;
      margin: 24px 0;
    }

    .callout p {
      color: rgba(255, 255, 255, 0.82);
      margin-bottom: 0;
    }

    .callout h3 {
      color: white;
    }

    .mini-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      font-weight: 750;
      margin-bottom: 8px;
    }

    .journey {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 12px;
      margin: 24px 0;
    }

    .journey-step {
      position: relative;
      background: white;
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 18px;
      min-height: 170px;
    }

    .journey-step::after {
      content: "→";
      position: absolute;
      right: -12px;
      top: 45%;
      color: var(--accent);
      font-weight: 800;
      font-size: 20px;
    }

    .journey-step:last-child::after {
      content: "";
    }

    .journey-number {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--accent);
      color: white;
      font-size: 13px;
      font-weight: 750;
      margin-bottom: 10px;
    }

    .journey-step h4 {
      font-size: 15px;
      margin-bottom: 8px;
    }

    .journey-step p {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 0;
    }

    .metric {
      font-size: 28px;
      font-weight: 750;
      color: var(--dark);
      margin-bottom: 4px;
    }

    .metric-label {
      color: var(--muted);
      font-size: 13px;
    }

    .footer {
      padding: 40px 0;
      color: var(--muted);
      font-size: 14px;
      border-top: 1px solid var(--line);
    }

    .small {
      font-size: 13px;
      color: var(--muted);
    }

    ul {
      padding-left: 20px;
      margin: 10px 0 0;
    }

    li {
      margin-bottom: 8px;
    }

    @media (max-width: 1000px) {
      .journey {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .journey-step::after {
        content: "";
      }

      .grid.four {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 800px) {
      nav {
        align-items: flex-start;
        gap: 12px;
        flex-direction: column;
      }

      nav .links {
        flex-wrap: wrap;
        gap: 12px;
      }

      .grid.two,
      .grid.three,
      .grid.four {
        grid-template-columns: 1fr;
      }

      .journey {
        grid-template-columns: 1fr;
      }

      .hero {
        padding-top: 58px;
      }
    }
  </style>
</head>

