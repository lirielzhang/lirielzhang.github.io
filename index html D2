<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wenli Zhang | Digital Marketing & Content Analytics</title>
  <style>
    :root {
      --bg: #07080c;
      --bg2: #10131a;
      --card: rgba(255, 255, 255, 0.075);
      --card2: rgba(255, 255, 255, 0.11);
      --line: rgba(255, 255, 255, 0.14);
      --text: #f7f7f2;
      --muted: #aeb6c2;
      --soft: #d7dce6;
      --accent: #9effc7;
      --accent2: #8bc7ff;
      --accent3: #e9d5ff;
      --warm: #f6d38b;
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
      --radius: 26px;
    }

    * {
      box-sizing: border-box;
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      background:
        radial-gradient(circle at 12% 10%, rgba(142, 199, 255, 0.22), transparent 28%),
        radial-gradient(circle at 90% 18%, rgba(158, 255, 199, 0.20), transparent 28%),
        radial-gradient(circle at 50% 92%, rgba(233, 213, 255, 0.16), transparent 32%),
        linear-gradient(180deg, var(--bg) 0%, var(--bg2) 52%, #07080c 100%);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,0.75), transparent 80%);
      z-index: -1;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(1120px, 92%);
      margin: 0 auto;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 99;
      backdrop-filter: blur(18px);
      background: rgba(7, 8, 12, 0.74);
      border-bottom: 1px solid var(--line);
    }

    nav {
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 760;
      letter-spacing: -0.03em;
    }

    .logo-mark {
      width: 28px;
      height: 28px;
      border-radius: 9px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      box-shadow: 0 0 26px rgba(158, 255, 199, 0.38);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 22px;
      font-size: 14px;
      color: var(--muted);
    }

    .nav-links a:hover {
      color: var(--text);
    }

    .hero {
      padding: 92px 0 76px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      color: var(--soft);
      font-size: 13px;
      margin-bottom: 24px;
    }

    .pulse {
      width: 7px;
      height: 7px;
      border-radius: 99px;
      background: var(--accent);
      box-shadow: 0 0 20px var(--accent);
    }

    h1 {
      max-width: 980px;
      margin: 0;
      font-size: clamp(46px, 7vw, 86px);
      line-height: 0.96;
      letter-spacing: -0.075em;
    }

    .gradient {
      background: linear-gradient(120deg, var(--accent), var(--accent2), var(--accent3));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-copy {
      max-width: 800px;
      margin: 26px 0 0;
      color: var(--muted);
      font-size: 19px;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 34px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border-radius: 14px;
      padding: 13px 18px;
      font-size: 14px;
      font-weight: 720;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.08);
      color: var(--text);
      transition: transform 0.2s ease, background 0.2s ease, border 0.2s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.13);
      border-color: rgba(255, 255, 255, 0.28);
    }

    .btn.primary {
      background: linear-gradient(135deg, rgba(158, 255, 199, 0.22), rgba(139, 199, 255, 0.22));
      border-color: rgba(158, 255, 199, 0.45);
      box-shadow: 0 0 35px rgba(158, 255, 199, 0.12);
    }

    section {
      padding: 58px 0;
    }

    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 22px;
      margin-bottom: 24px;
    }

    h2 {
      margin: 0;
      font-size: clamp(30px, 4vw, 48px);
      line-height: 1.05;
      letter-spacing: -0.055em;
    }

    .section-note {
      max-width: 520px;
      color: var(--muted);
      margin: 0;
    }

    .grid {
      display: grid;
      gap: 18px;
    }

    .grid.two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .grid.three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .card {
      position: relative;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: linear-gradient(180deg, rgba(255,255,255,0.105), rgba(255,255,255,0.055));
      box-shadow: var(--shadow);
      padding: 26px;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: -1px;
      background: radial-gradient(circle at top right, rgba(158, 255, 199, 0.16), transparent 35%);
      pointer-events: none;
    }

    .card > * {
      position: relative;
      z-index: 1;
    }

    .case-card {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 22px;
      align-items: stretch;
      padding: 0;
    }

    .case-content {
      padding: 32px;
    }

    .case-visual {
      min-height: 360px;
      padding: 24px;
      background:
        radial-gradient(circle at 20% 20%, rgba(158,255,199,0.25), transparent 24%),
        radial-gradient(circle at 80% 70%, rgba(139,199,255,0.24), transparent 26%),
        rgba(255,255,255,0.045);
      border-left: 1px solid var(--line);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .label {
      display: inline-block;
      color: var(--accent);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.10em;
      font-weight: 800;
      margin-bottom: 10px;
    }

    h3 {
      margin: 0 0 10px;
      font-size: 24px;
      letter-spacing: -0.035em;
      line-height: 1.18;
    }

    h4 {
      margin: 0 0 8px;
      font-size: 17px;
      letter-spacing: -0.02em;
    }

    p {
      margin: 0;
      color: var(--muted);
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 18px;
    }

    .tag {
      font-size: 12px;
      font-weight: 700;
      color: var(--soft);
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(255,255,255,0.07);
      padding: 6px 10px;
      border-radius: 999px;
    }

    .mini-flow {
      display: grid;
      gap: 10px;
    }

    .flow-item {
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(7,8,12,0.34);
      border-radius: 16px;
      padding: 13px 14px;
      font-size: 13px;
      color: var(--soft);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .flow-item span {
      color: var(--accent);
      font-weight: 800;
    }

    .skill-card {
      min-height: 210px;
    }

    .icon {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: rgba(158, 255, 199, 0.12);
      border: 1px solid rgba(158, 255, 199, 0.28);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
      color: var(--accent);
      font-weight: 900;
    }

    .project-card {
      min-height: 250px;
    }

    .footer {
      border-top: 1px solid var(--line);
      padding: 42px 0;
      color: var(--muted);
      font-size: 14px;
    }

    @media (max-width: 900px) {
      .case-card,
      .grid.two,
      .grid.three {
        grid-template-columns: 1fr;
      }

      .case-visual {
        border-left: 0;
        border-top: 1px solid var(--line);
      }

      .section-head {
        display: block;
      }

      .section-note {
        margin-top: 12px;
      }
    }

    @media (max-width: 720px) {
      nav {
        height: auto;
        padding: 16px 0;
        align-items: flex-start;
        flex-direction: column;
        gap: 12px;
      }

      .nav-links {
        flex-wrap: wrap;
        gap: 12px;
      }

      .hero {
        padding-top: 62px;
      }

      .case-content {
        padding: 24px;
      }
    }
  </style>
</head>

